# Configuración de Base de Datos PostgreSQL
DB_HOST=192.168.1.16
DB_PORT=5432
DB_NAME=lazoexpresscore
DB_REGISTRY_NAME=lazoexpressregistry
DB_USER=postgres
DB_PASSWORD='$Novus315.'

# Configuración del servidor
APP_HOST=0.0.0.0
APP_PORT=8020
DEBUG=True

# Servicio de impresión Python (puerto donde corre print service)
PRINT_SERVICE_URL=http://192.168.1.16:8001

# LazoExpress Java (puerto 8010 normalmente)
LAZOEXPRESS_URL=http://192.168.1.16:8010

# ─── Sistema de Licencias (HO - Head Office) ─────────────────────────────────
# URL del servidor de la HO que valida los códigos numéricos de licencia.
# Por defecto usa el mismo endpoint que usaba el sistema Java.
LICENSE_SERVER_URL=http://127.0.0.1:8012/v1.0/mqtt/register

# Header de autenticación para el servidor de la HO (igual que Java).
# ISO 27001 A.14: nunca hardcodear credenciales en código fuente.
LICENSE_AUTH_HEADER=Basic cGFzc3BvcnR4OlQ0MUFYUWtYSjh6

# ─── Gilbarco Core ─────────────────────────────────────────────────────────────
# API local/remota de Gilbarco para saltos de lectura y otros comandos
GILBARCO_CORE_URL=http://192.168.1.16:8000/api
